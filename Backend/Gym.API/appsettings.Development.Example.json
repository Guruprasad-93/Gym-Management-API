{
  "_comment": "Copy to appsettings.Development.json for local development. Do not commit real secrets.",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=GymDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "GymManagementSystem",
    "Audience": "GymManagementSystem",
    "ExpiryMinutes": 120,
    "RefreshTokenExpiryDays": 7,
    "PasswordResetTokenExpiryMinutes": 60,
    "ReturnResetTokenInDevelopment": true
  },
  "PasswordReset": {
    "FrontendBaseUrl": "http://localhost:4200"
  },
  "Bootstrap": {
    "SuperAdminEmail": "superadmin@gym.com"
  },
  "Demo": {
    "Enabled": true,
    "Password": "CHANGE_ME"
  },
  "FileStorage": {
    "Provider": "Local",
    "LocalRootPath": "uploads"
  },
  "Database": {
    "RunMigrationsOnStartup": true,
    "RunSeedOnStartup": true
  },
  "AuthCookies": {
    "UseCookieAuth": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  }
}
