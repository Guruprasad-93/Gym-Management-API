# Gym Management API — environment variables (Phase 0)
# ASP.NET Core maps Jwt__Secret to Jwt:Secret automatically; aliases below also supported.

JWT_SECRET=your-production-secret-minimum-32-characters
JWT_ISSUER=GymManagementSystem
JWT_AUDIENCE=GymManagementSystem
DATABASE_CONNECTION=Server=.;Database=GymDb;Trusted_Connection=True;TrustServerCertificate=True
BOOTSTRAP_SUPERADMIN_EMAIL=superadmin@gym.com
BOOTSTRAP_SUPERADMIN_PASSWORD=change-me-on-deploy
PASSWORD_RESET_FRONTEND_URL=http://localhost:4200

# Development only (User Secrets recommended instead):
# dotnet user-secrets set "Jwt:Secret" "DevOnlySecretKey_AtLeast32CharsLong!"
# dotnet user-secrets set "Bootstrap:SuperAdminPassword" "SuperAdmin@123"
